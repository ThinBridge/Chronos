// ‰pŒê resources

#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_ENU)
LANGUAGE LANG_ENGLISH, SUBLANG_NEUTRAL
#pragma code_page(1252)

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New Window\tCtrl+N",         ID_NEW_BLANK
        MENUITEM "New Window (with Current Page)", ID_NEW
        MENUITEM "New Session",                 ID_NEW_SESSION
        MENUITEM SEPARATOR
        MENUITEM "Restore Window",              ID_RESTORE_WND
        MENUITEM "Save Window",                 ID_SAVE_WND
        MENUITEM SEPARATOR
        MENUITEM "Print to PDF",                ID_PRINT_PDF
        MENUITEM "&Print...\tCtrl+P",           ID_PRINT
        MENUITEM SEPARATOR
        MENUITEM "&Close",                      ID_W_CLOSE
        MENUITEM SEPARATOR
        POPUP "Recently Closed Windows"
        BEGIN
            MENUITEM "No Item",                     ID_CLOSE_WND_HISTORY_DUMMY
        END
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "Cu&t\tCtrl+X",                ID_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_PASTE
        MENUITEM SEPARATOR
        MENUITEM "Select &All\tCtrl+A",         ID_SEL_ALL
        MENUITEM SEPARATOR
        MENUITEM "&Find on this Page...\tCtrl+F", ID_FIND_PAGE
    END
    POPUP "&View"
    BEGIN
        MENUITEM "Back\t Alt+پ©",               ID_GO_BACK
        MENUITEM "Forward\t Alt+پ¨",            ID_GO_FORWARD
        MENUITEM "Stop\tEsc",                   ID_VIEW_STOP
        MENUITEM "Refresh\t F5",                ID_VIEW_REFRESH
        MENUITEM "Home Page\tAlt+Home",         ID_GO_START_PAGE
        MENUITEM SEPARATOR
        MENUITEM "&Full Screen\tF11",           ID_FULL_SCREEN
    END
    POPUP "F&avorites"
    BEGIN
        MENUITEM "&Add to favorites...",        ID_ADD_FAVORITE
        MENUITEM "&Organize favorites...",      ID_ORGANIZE_FAVORITE
        MENUITEM SEPARATOR
        MENUITEM "DUMMY",                       ID_FAVORITE_DUMMY
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&File Manager",               ID_OPEN_THIN_FILER
        MENUITEM SEPARATOR
        MENUITEM "&Preferences...",             ID_SETTINGS
    END
    POPUP "&Window"
    BEGIN
        MENUITEM "&Close",                      ID_W_CLOSE
        MENUITEM "Close All Winodws (&X)",      IDC_APP_EXIT
        MENUITEM "Close All Windows But this",  IDC_APP_EXIT_BUT_THIS
        MENUITEM "Next Window\tCtrl+Tab",       ID_NEXT_WND
        MENUITEM "Previous Window\tShift+Ctrl+Tab", ID_PREV_WND
        MENUITEM SEPARATOR
        MENUITEM "DUMMY",                       ID_WINDOW_DUMMY
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About...",                   ID_APP_ABOUT
        MENUITEM SEPARATOR
        MENUITEM "Cleanup Browser Cache (&X)",  IDC_APP_DELETE_CACHE
    END
END

IDR_MENU_BACK MENU
BEGIN
    POPUP "BACK"
    BEGIN
        MENUITEM "Go Back 1 entry",             ID_BF_BACK1
        MENUITEM "Go Back 2 entries",           ID_BF_BACK2
        MENUITEM "Go Back 3 entries",           ID_BF_BACK3
        MENUITEM "Go Back 4 entries",           ID_BF_BACK4
        MENUITEM "Go Back 5 entries",           ID_BF_BACK5
    END
END

IDR_MENU_FORWARD MENU
BEGIN
    POPUP "FORWARD"
    BEGIN
        MENUITEM "Go Forward 1 entry",          ID_BF_FORWARD1
        MENUITEM "Go Forward 2 entries",        ID_BF_FORWARD2
        MENUITEM "Go Forward 3 entries",        ID_BF_FORWARD3
        MENUITEM "Go Forward 4 entries",        ID_BF_FORWARD4
        MENUITEM "Go Forward 5 entries",        ID_BF_FORWARD5
    END
END

IDR_MENU_TAB MENU
BEGIN
    POPUP "TAB_MENU"
    BEGIN
        MENUITEM "New Tab",                     ID_NEW_BLANK
        MENUITEM "Suplicate Tab",               ID_NEW
        MENUITEM SEPARATOR
        MENUITEM "Close Tab",                   ID_W_CLOSE
        MENUITEM "Close All Windows But this (&X)", IDC_APP_EXIT
        MENUITEM "Close All Tabs But this",     IDC_APP_EXIT_BUT_THIS
        MENUITEM "Close Tabs to Right",         ID_TAB_CLOSE_RIGHT
        MENUITEM "Close Tabs to Left",          ID_TAB_CLOSE_LEFT
    END
END


